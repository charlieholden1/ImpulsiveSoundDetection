# Copy this file to .env and fill in ADMIN_PASSWORD_HASH.
#
# Generate the hash with (from this directory):
#   node -e "require('bcrypt').hash('your-password', 12).then(console.log)"
# or:
#   npm run hash your-password
#
# IMPORTANT — $ escaping:
#   Docker Compose interpolates $ signs in .env values, which silently
#   corrupts a bcrypt hash ($2b$12$... has three $ signs at the start).
#   Every $ in the hash must be written as $$ in this file.
#
#   Example — if the hash is:  $2b$12$XYZabc...
#   Write in this file:        $$2b$$12$$XYZabc...
#
#   Only the three leading $ signs need escaping ($2b$12$).
#   The rest of the 60-character hash contains no $ signs.

ADMIN_PASSWORD_HASH=
